# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=armenian_osint
DB_USER=postgres
DB_PASSWORD=your_password_here

# AI Configuration
# Set to 'true' to enable AI-powered SQL generation
# Set to 'false' to use basic pattern matching (no AI needed)
ENABLE_AI_SQL=false

# LLM Configuration (only needed if ENABLE_AI_SQL=true)
# Uncomment ONE of the following options:

# Option 1: OpenAI (recommended for production)
# OPENAI_API_KEY=sk-your-key-here
# DEFAULT_LLM_PROVIDER=openai

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=your-key-here
# DEFAULT_LLM_PROVIDER=anthropic

# Option 3: Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434
# DEFAULT_LLM_PROVIDER=ollama

# Security
JWT_SECRET=your_jwt_secret_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Threat Intelligence (optional — security tab features)
# VirusTotal free tier: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-virustotal-key-here
# Have I Been Pwned: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your-hibp-key-here

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
