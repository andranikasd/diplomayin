{
  "name": "armenian-osint-analytics",
  "version": "1.0.0",
  "description": "Professional chatbot application for Armenian OSINT marketing analytics",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "cf:dev": "wrangler pages dev public --compatibility-date=2024-12-18",
    "cf:deploy": "wrangler pages deploy public --project-name=armdata",
    "cf:db:create": "wrangler d1 create armdata-db",
    "cf:db:migrate": "wrangler d1 execute armdata-db --file=migrations/0001_schema.sql --remote",
    "cf:db:migrate:local": "wrangler d1 execute armdata-db --file=migrations/0001_schema.sql",
    "cf:secret:jwt": "wrangler pages secret put JWT_SECRET --project-name=armdata",
    "cf:secret:openai": "wrangler pages secret put OPENAI_API_KEY --project-name=armdata",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "osint",
    "analytics",
    "chatbot",
    "armenian",
    "ai",
    "sql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.14.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^0.1.0",
    "openai": "^4.24.1",
    "pg": "^8.11.3",
    "socket.io": "^4.6.1",
    "sql-query-identifier": "^2.6.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "hono": "^4.12.8",
    "nodemon": "^3.0.2",
    "wrangler": "^3.114.17"
  }
}
